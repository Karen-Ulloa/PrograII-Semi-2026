<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <EditText
            android:id="@+id/txtcodigoAmigos"
            android:hint="Código"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/txtdescripcionAmigos"
            android:hint="Descripción"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/txtmarcaAmigos"
            android:hint="Marca"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/txtpresentacionAmigos"
            android:hint="Presentación"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- COSTO -->
        <EditText
            android:id="@+id/txtCosto"
            android:hint="Costo"
            android:inputType="numberDecimal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- STOCK -->
        <EditText
            android:id="@+id/txtStock"
            android:hint="Stock"
            android:inputType="number"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- PRECIO AUTOMÁTICO -->
        <EditText
            android:id="@+id/txtprecioAmigos"
            android:hint="Precio (automático)"
            android:enabled="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <ImageButton
            android:id="@+id/imgFotoAmigo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"
            android:src="@drawable/camara"/>

        <Button
            android:id="@+id/btnGuardarAmigo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Guardar Producto"
            android:layout_marginTop="20dp"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabListaAmigo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="20dp"
            android:src="@android:drawable/ic_media_previous"
            app:backgroundTint="@color/accent"/>

    </LinearLayout>

</ScrollView>