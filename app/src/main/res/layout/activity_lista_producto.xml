<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A">

    <!-- Encabezado -->
    <LinearLayout
        android:id="@+id/layoutEncabezado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🛒 Tienda de Zapatos"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.05"
            android:layout_marginBottom="14dp"/>

        <EditText
            android:id="@+id/txtBuscarProductos"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="🔍  Buscar producto..."
            android:textColor="#FFFFFF"
            android:textColorHint="#BBDEFB"
            android:textSize="14sp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:inputType="text"/>

    </LinearLayout>

    <!-- SwipeRefreshLayout envuelve solo la lista -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layoutEncabezado"
        android:layout_above="@id/fabAgregarProductos"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp">

        <ListView
            android:id="@+id/ltsProductos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="#141D2E"
            android:dividerHeight="1dp"
            android:scrollbars="none"
            tools:ignore="UnknownId"/>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Botón agregar -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAgregarProductos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="20dp"
        android:src="@android:drawable/ic_input_add"
        android:tint="@color/white"
        android:contentDescription="Agregar producto"
        app:backgroundTint="#1565C0"
        app:elevation="8dp"
        app:fabSize="normal"/>

</RelativeLayout>